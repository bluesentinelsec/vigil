{
  "scopeName": "source.basl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.basl", "match": "//.*$" },
        { "name": "comment.block.basl", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.interpolated.basl",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.basl", "match": "\\\\[nrt\\\\\"{}]" },
            {
              "name": "meta.interpolation.basl",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.basl" } },
              "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.basl" } },
              "patterns": [{ "include": "source.basl" }]
            }
          ]
        },
        {
          "name": "string.quoted.double.basl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.basl", "match": "\\\\[nrt\\\\\"0]" }
          ]
        },
        {
          "name": "string.quoted.other.raw.basl",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.basl", "match": "\\b0[xX][0-9a-fA-F]+\\b" },
        { "name": "constant.numeric.float.basl", "match": "\\b\\d+\\.\\d*([eE][+-]?\\d+)?\\b" },
        { "name": "constant.numeric.float.basl", "match": "\\b\\d+[eE][+-]?\\d+\\b" },
        { "name": "constant.numeric.integer.basl", "match": "\\b\\d+\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.basl",
          "match": "\\b(if|else|while|for|break|continue|return|switch|case|default|defer|in)\\b"
        },
        {
          "name": "keyword.declaration.basl",
          "match": "\\b(fn|class|interface|enum|const|import|as|pub|implements)\\b"
        },
        {
          "name": "variable.language.basl",
          "match": "\\b(self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.basl",
          "match": "\\b(bool|i32|i64|f64|u8|u32|u64|string|void|err|array|map)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.boolean.basl", "match": "\\b(true|false)\\b" },
        { "name": "constant.language.ok.basl", "match": "\\bok\\b" },
        { "name": "constant.language.errkind.basl", "match": "\\berr\\.(not_found|permission|exists|eof|io|parse|bounds|type|arg|timeout|closed|state)\\b" }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.basl",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": { "1": { "name": "entity.name.function.basl" } }
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.comparison.basl", "match": "==|!=|<=|>=|<|>" },
        { "name": "keyword.operator.logical.basl", "match": "&&|\\|\\||!" },
        { "name": "keyword.operator.assignment.basl", "match": "\\+=|-=|\\*=|/=|%=|=" },
        { "name": "keyword.operator.arithmetic.basl", "match": "\\+\\+|--|\\+|-|\\*|/|%" },
        { "name": "keyword.operator.arrow.basl", "match": "->" }
      ]
    }
  }
}
