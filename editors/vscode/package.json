{
  "name": "basl",
  "displayName": "BASL",
  "description": "Syntax highlighting plus a local BASL language server client for diagnostics, navigation, rename, symbols, and completions",
  "version": "0.1.0",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "main": "./extension.js",
  "activationEvents": ["onLanguage:basl"],
  "contributes": {
    "languages": [{
      "id": "basl",
      "aliases": ["BASL"],
      "extensions": [".basl"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "basl",
      "scopeName": "source.basl",
      "path": "./syntaxes/basl.tmLanguage.json"
    }],
    "snippets": [{
      "language": "basl",
      "path": "./snippets/basl.json"
    }],
    "configuration": {
      "title": "BASL",
      "properties": {
        "basl.path": {
          "type": "string",
          "default": "basl",
          "description": "Path to the basl CLI used to launch `basl lsp` for diagnostics, definitions, hover, rename, references, symbols, and completions."
        }
      }
    }
  }
}
