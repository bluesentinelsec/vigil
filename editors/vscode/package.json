{
  "name": "basl",
  "displayName": "BASL",
  "description": "Syntax highlighting, snippets, and stdlib completions for BASL",
  "version": "0.1.0",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "main": "./extension.js",
  "activationEvents": ["onLanguage:basl"],
  "contributes": {
    "languages": [{
      "id": "basl",
      "aliases": ["BASL"],
      "extensions": [".basl"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "basl",
      "scopeName": "source.basl",
      "path": "./syntaxes/basl.tmLanguage.json"
    }],
    "snippets": [{
      "language": "basl",
      "path": "./snippets/basl.json"
    }]
  }
}
