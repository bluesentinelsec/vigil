// ============================================================================
// thread_stress_test.basl — Comprehensive thread module stress test
//
// Exercises every available thread primitive:
//   thread: spawn, join, current_id, yield, sleep, mutex, lock, unlock,
//           try_lock, cond, wait, signal, broadcast, rwlock, read_lock,
//           write_lock, rw_unlock
//   atomic: new, load, store, add, sub, cas, inc, dec
//
// Structure:
//   Section 1 — Sequential baseline (Monte Carlo pi estimation)
//   Section 2 — Parallel Monte Carlo with 50+ threads
//   Section 3 — Producer-consumer pipeline with bounded queue
//   Section 4 — Reader-writer lock contention test
//   Section 5 — try_lock spin loop and yield stress
//   Section 6 — CAS-based lock-free counter
//   Section 7 — Broadcast wakeup (barrier emulation)
//   Section 8 — Result comparison and report
// ============================================================================

import "thread";
import "atomic";
import "fmt";
import "time";
import "math";

// ── Configuration ───────────────────────────────────────────────────────────

const i64 NUM_WORKERS       = i64(50);   // total worker threads
const i64 ITERS_PER_WORKER  = i64(200000); // Monte Carlo samples per worker
const i64 NUM_PRODUCERS     = i64(8);
const i64 NUM_CONSUMERS     = i64(8);
const i64 TASKS_PER_PRODUCER = i64(50);
const i64 QUEUE_CAPACITY    = i64(100);
const i64 RW_READERS        = i64(10);
const i64 RW_WRITERS        = i64(4);
const i64 RW_OPS_PER_THREAD = i64(500);
const i64 TRYLOCK_THREADS   = i64(8);
const i64 TRYLOCK_ITERS     = i64(1000);
const i64 CAS_THREADS       = i64(16);
const i64 CAS_ITERS         = i64(5000);
const i64 BROADCAST_THREADS = i64(20);

// ============================================================================
// Section 1: Sequential Monte Carlo pi estimation (baseline)
// ============================================================================

fn lcg_next(i64 state) -> i64 {
    // Linear congruential generator: state = (a * state + c) mod m
    // Using Numerical Recipes constants (mod 2^31)
    i64 a = i64(1103515245);
    i64 c = i64(12345);
    i64 m = i64(2147483648); // 2^31
    return (a * state + c) % m;
}

fn monte_carlo_sequential(i64 total_iters) -> i64 {
    // Returns count of points inside unit circle (scaled by 4 for pi)
    i64 inside = i64(0);
    i64 rng = i64(42); // seed
    i64 m = i64(2147483648);
    for (i64 i = i64(0); i < total_iters; i = i + i64(1)) {
        rng = lcg_next(rng);
        i64 xi = rng % i64(10000);
        rng = lcg_next(rng);
        i64 yi = rng % i64(10000);
        // x, y in [0, 10000); check if x^2 + y^2 < 10000^2
        if (xi * xi + yi * yi < i64(100000000)) {
            inside = inside + i64(1);
        }
    }
    return inside;
}

// ============================================================================
// Section 2: Parallel Monte Carlo with NUM_WORKERS threads
//   Primitives: spawn, join, mutex, lock, unlock, atomic.add, atomic.load,
//               current_id, sleep
// ============================================================================

fn monte_carlo_worker(i64 iters, i64 seed, i64 hit_counter) -> void {
    i64 inside = i64(0);
    i64 rng = seed;
    for (i64 i = i64(0); i < iters; i = i + i64(1)) {
        rng = lcg_next(rng);
        i64 xi = rng % i64(10000);
        rng = lcg_next(rng);
        i64 yi = rng % i64(10000);
        if (xi * xi + yi * yi < i64(100000000)) {
            inside = inside + i64(1);
        }
    }
    atomic.add(hit_counter, inside);
}

// ============================================================================
// Section 3: Producer-consumer pipeline
//   Primitives: mutex, lock, unlock, cond, wait, signal, broadcast,
//               atomic.add, atomic.load, atomic.store, atomic.inc, atomic.dec
//
//   Bounded queue of size QUEUE_CAPACITY. Producers enqueue task IDs,
//   consumers dequeue and "process" them (sum the IDs). Poison pill = -1.
// ============================================================================

// Queue state stored in atomics:
//   queue slots: atomic array (indices 0..QUEUE_CAPACITY-1)
//   head, tail, count: atomics for queue bookkeeping
//   done_flag: signals consumers to exit

fn producer_work(i64 id, i64 tasks, i64 q_mtx, i64 q_not_full, i64 q_not_empty,
                 i64 q_head, i64 q_tail, i64 q_count, i64 q_base,
                 i64 produced_total) -> void {
    for (i64 t = i64(0); t < tasks; t = t + i64(1)) {
        i64 task_val = id * i64(1000) + t; // unique task ID
        thread.lock(q_mtx);
        // Wait while queue is full
        for (; atomic.load(q_count) >= QUEUE_CAPACITY; ) {
            thread.wait(q_not_full, q_mtx);
        }
        // Enqueue
        i64 tail = atomic.load(q_tail);
        i64 slot = q_base + tail;
        atomic.store(slot, task_val);
        atomic.store(q_tail, (tail + i64(1)) % QUEUE_CAPACITY);
        atomic.inc(q_count);
        thread.signal(q_not_empty);
        thread.unlock(q_mtx);
    }
    atomic.add(produced_total, tasks);
}

fn consumer_work(i64 q_mtx, i64 q_not_full, i64 q_not_empty,
                 i64 q_head, i64 q_tail, i64 q_count, i64 q_base,
                 i64 done_flag, i64 consumed_sum, i64 consumed_count) -> void {
    for (;;) {
        thread.lock(q_mtx);
        // Wait while queue is empty and not done
        for (; atomic.load(q_count) == i64(0); ) {
            if (atomic.load(done_flag) == i64(1)) {
                thread.unlock(q_mtx);
                return;
            }
            thread.wait(q_not_empty, q_mtx);
        }
        // Check again after wakeup
        if (atomic.load(q_count) == i64(0)) {
            thread.unlock(q_mtx);
            if (atomic.load(done_flag) == i64(1)) {
                return;
            }
            continue;
        }
        // Dequeue
        i64 head = atomic.load(q_head);
        i64 slot = q_base + head;
        i64 val = atomic.load(slot);
        atomic.store(q_head, (head + i64(1)) % QUEUE_CAPACITY);
        atomic.dec(q_count);
        thread.signal(q_not_full);
        thread.unlock(q_mtx);
        // "Process" the task: accumulate its value
        atomic.add(consumed_sum, val);
        atomic.inc(consumed_count);
    }
}

// ============================================================================
// Section 4: Reader-writer lock contention
//   Primitives: rwlock, read_lock, write_lock, rw_unlock, atomic.add
// ============================================================================

fn reader_work(i64 rw, i64 shared_val, i64 read_sum, i64 ops) -> void {
    for (i64 i = i64(0); i < ops; i = i + i64(1)) {
        thread.read_lock(rw);
        i64 v = atomic.load(shared_val);
        thread.rw_unlock(rw);
        atomic.add(read_sum, v);
    }
}

fn writer_work(i64 rw, i64 shared_val, i64 ops) -> void {
    for (i64 i = i64(0); i < ops; i = i + i64(1)) {
        thread.write_lock(rw);
        atomic.inc(shared_val);
        thread.rw_unlock(rw);
    }
}

// ============================================================================
// Section 5: try_lock spin loop + yield stress
//   Primitives: try_lock, unlock, yield, atomic.inc
// ============================================================================

fn trylock_worker(i64 mtx, i64 counter, i64 iters) -> void {
    for (i64 i = i64(0); i < iters; i = i + i64(1)) {
        for (; !thread.try_lock(mtx); ) {
            thread.yield();
        }
        atomic.inc(counter);
        thread.unlock(mtx);
    }
}

// ============================================================================
// Section 6: CAS-based lock-free counter
//   Primitives: atomic.load, atomic.cas
// ============================================================================

fn cas_worker(i64 counter, i64 iters) -> void {
    for (i64 i = i64(0); i < iters; i = i + i64(1)) {
        for (;;) {
            i64 old = atomic.load(counter);
            if (atomic.cas(counter, old, old + i64(1))) {
                break;
            }
        }
    }
}

// ============================================================================
// Section 7: Broadcast barrier emulation
//   Primitives: cond, broadcast, wait, mutex, lock, unlock, atomic.inc,
//               atomic.load, atomic.sub
// ============================================================================

fn barrier_worker(i64 bar_mtx, i64 bar_cond, i64 arrived, i64 total,
                  i64 result_counter) -> void {
    // Phase 1: arrive at barrier
    thread.lock(bar_mtx);
    atomic.inc(arrived);
    if (atomic.load(arrived) == total) {
        // Last thread: wake everyone
        thread.broadcast(bar_cond);
    } else {
        // Wait for all to arrive
        for (; atomic.load(arrived) < total; ) {
            thread.wait(bar_cond, bar_mtx);
        }
    }
    thread.unlock(bar_mtx);
    // Phase 2: all threads past barrier, do work
    atomic.inc(result_counter);
}

// ============================================================================
// Section 8: Main — run all sections, compare, report
// ============================================================================

fn main() -> i32 {
    fmt.println("=== BASL Thread Stress Test ===");
    fmt.println("");

    i64 total_iters = NUM_WORKERS * ITERS_PER_WORKER;

    // ── Section 1: Sequential baseline ──────────────────────────────────
    fmt.println("[1] Sequential Monte Carlo pi estimation...");
    i64 t0 = time.now_ms();
    i64 seq_hits = monte_carlo_sequential(total_iters);
    i64 t1 = time.now_ms();
    i64 seq_ms = t1 - t0;
    fmt.println(f"    Iterations: {total_iters}");
    fmt.println(f"    Hits: {seq_hits}");
    fmt.println(f"    Time: {seq_ms} ms");

    // ── Section 2: Parallel Monte Carlo ─────────────────────────────────
    fmt.println("");
    fmt.println(f"[2] Parallel Monte Carlo ({NUM_WORKERS} threads)...");
    i64 par_hits = atomic.new(i64(0));
    i64 t2 = time.now_ms();

    // Spawn NUM_WORKERS threads, each with a unique seed
    // Store thread handles in atomics (workaround: no arrays of handles)
    i64 th_base = atomic.new(i64(0)); // handle storage base
    // We'll allocate NUM_WORKERS atomics to hold thread handles
    // Actually, we need to spawn and join in a loop. Since we can't
    // use arrays, we'll spawn in batches and join immediately per batch.
    // Better approach: allocate atomic slots for handles.

    // Allocate handle storage
    i64 handles_base = atomic.new(i64(0)); // slot 0 of handles
    // Pre-allocate remaining handle slots
    for (i64 i = i64(1); i < NUM_WORKERS; i = i + i64(1)) {
        atomic.new(i64(0));
    }
    // handles_base through handles_base + NUM_WORKERS - 1 are our handle slots

    for (i64 i = i64(0); i < NUM_WORKERS; i = i + i64(1)) {
        i64 seed = i64(1000) + i * i64(7919); // unique seed per thread
        i64 iters = ITERS_PER_WORKER;
        i64 hits = par_hits;
        i64 t = thread.spawn(fn() -> void {
            monte_carlo_worker(iters, seed, hits);
        });
        atomic.store(handles_base + i, t);
    }

    for (i64 i = i64(0); i < NUM_WORKERS; i = i + i64(1)) {
        i64 h = atomic.load(handles_base + i);
        thread.join(h);
    }

    i64 t3 = time.now_ms();
    i64 par_ms = t3 - t2;
    i64 par_result = atomic.load(par_hits);
    fmt.println(f"    Hits: {par_result}");
    fmt.println(f"    Time: {par_ms} ms");
    if (par_ms > i64(0)) {
        fmt.println(f"    Speedup: ~{seq_ms / par_ms}x");
    }

    // ── Section 3: Producer-consumer pipeline ───────────────────────────
    fmt.println("");
    fmt.println("[3] Producer-consumer pipeline...");
    fmt.println(f"    {NUM_PRODUCERS} producers x {TASKS_PER_PRODUCER} tasks, {NUM_CONSUMERS} consumers, queue cap {QUEUE_CAPACITY}");

    i64 q_mtx = thread.mutex();
    i64 q_not_full = thread.cond();
    i64 q_not_empty = thread.cond();
    i64 q_head = atomic.new(i64(0));
    i64 q_tail = atomic.new(i64(0));
    i64 q_count = atomic.new(i64(0));
    // Allocate queue buffer slots
    i64 q_base = atomic.new(i64(0));
    for (i64 i = i64(1); i < QUEUE_CAPACITY; i = i + i64(1)) {
        atomic.new(i64(0));
    }
    i64 done_flag = atomic.new(i64(0));
    i64 produced_total = atomic.new(i64(0));
    i64 consumed_sum = atomic.new(i64(0));
    i64 consumed_count = atomic.new(i64(0));

    i64 t4 = time.now_ms();

    // Spawn producers
    i64 prod_handles = atomic.new(i64(0));
    for (i64 i = i64(1); i < NUM_PRODUCERS; i = i + i64(1)) {
        atomic.new(i64(0));
    }
    for (i64 i = i64(0); i < NUM_PRODUCERS; i = i + i64(1)) {
        i64 pid = i;
        i64 tasks = TASKS_PER_PRODUCER;
        i64 pt = produced_total;
        i64 t = thread.spawn(fn() -> void {
            producer_work(pid, tasks, q_mtx, q_not_full, q_not_empty,
                          q_head, q_tail, q_count, q_base, pt);
        });
        atomic.store(prod_handles + i, t);
    }

    // Spawn consumers
    i64 cons_handles = atomic.new(i64(0));
    for (i64 i = i64(1); i < NUM_CONSUMERS; i = i + i64(1)) {
        atomic.new(i64(0));
    }
    for (i64 i = i64(0); i < NUM_CONSUMERS; i = i + i64(1)) {
        i64 t = thread.spawn(fn() -> void {
            consumer_work(q_mtx, q_not_full, q_not_empty,
                          q_head, q_tail, q_count, q_base,
                          done_flag, consumed_sum, consumed_count);
        });
        atomic.store(cons_handles + i, t);
    }

    // Join producers
    for (i64 i = i64(0); i < NUM_PRODUCERS; i = i + i64(1)) {
        thread.join(atomic.load(prod_handles + i));
    }

    // Signal done and wake all consumers
    atomic.store(done_flag, i64(1));
    // Broadcast to wake any waiting consumers
    thread.lock(q_mtx);
    thread.broadcast(q_not_empty);
    thread.unlock(q_mtx);

    // Join consumers
    for (i64 i = i64(0); i < NUM_CONSUMERS; i = i + i64(1)) {
        thread.join(atomic.load(cons_handles + i));
    }

    i64 t5 = time.now_ms();
    i64 pc_ms = t5 - t4;
    i64 total_produced = atomic.load(produced_total);
    i64 total_consumed = atomic.load(consumed_count);
    i64 total_sum = atomic.load(consumed_sum);

    // Compute expected sum: each producer i produces tasks with values i*1000+t
    // for t in [0, TASKS_PER_PRODUCER). Sum = sum over all producers and tasks.
    i64 expected_sum = i64(0);
    for (i64 p = i64(0); p < NUM_PRODUCERS; p = p + i64(1)) {
        for (i64 t = i64(0); t < TASKS_PER_PRODUCER; t = t + i64(1)) {
            expected_sum = expected_sum + p * i64(1000) + t;
        }
    }

    fmt.println(f"    Produced: {total_produced}, Consumed: {total_consumed}");
    fmt.println(f"    Sum: {total_sum} (expected: {expected_sum})");
    fmt.println(f"    Time: {pc_ms} ms");
    if (total_consumed != total_produced) {
        fmt.println("    *** FAIL: produced != consumed ***");
    }
    if (total_sum != expected_sum) {
        fmt.println("    *** FAIL: sum mismatch ***");
    }

    // ── Section 4: Reader-writer lock contention ────────────────────────
    fmt.println("");
    fmt.println("[4] Reader-writer lock contention...");
    i64 rw = thread.rwlock();
    i64 shared_val = atomic.new(i64(0));
    i64 read_sum = atomic.new(i64(0));

    i64 t6 = time.now_ms();

    i64 rw_handles = atomic.new(i64(0));
    i64 rw_total = RW_READERS + RW_WRITERS;
    for (i64 i = i64(1); i < rw_total; i = i + i64(1)) {
        atomic.new(i64(0));
    }

    // Spawn readers
    for (i64 i = i64(0); i < RW_READERS; i = i + i64(1)) {
        i64 ops = RW_OPS_PER_THREAD;
        i64 t = thread.spawn(fn() -> void {
            reader_work(rw, shared_val, read_sum, ops);
        });
        atomic.store(rw_handles + i, t);
    }
    // Spawn writers
    for (i64 i = i64(0); i < RW_WRITERS; i = i + i64(1)) {
        i64 ops = RW_OPS_PER_THREAD;
        i64 t = thread.spawn(fn() -> void {
            writer_work(rw, shared_val, ops);
        });
        atomic.store(rw_handles + RW_READERS + i, t);
    }

    for (i64 i = i64(0); i < rw_total; i = i + i64(1)) {
        thread.join(atomic.load(rw_handles + i));
    }

    i64 t7 = time.now_ms();
    i64 rw_ms = t7 - t6;
    i64 final_shared = atomic.load(shared_val);
    i64 expected_writes = RW_WRITERS * RW_OPS_PER_THREAD;
    fmt.println(f"    Writers: {RW_WRITERS} x {RW_OPS_PER_THREAD} ops = {expected_writes} expected increments");
    fmt.println(f"    Final shared value: {final_shared}");
    fmt.println(f"    Time: {rw_ms} ms");
    if (final_shared != expected_writes) {
        fmt.println("    *** FAIL: write count mismatch ***");
    }

    // ── Section 5: try_lock spin + yield ────────────────────────────────
    fmt.println("");
    fmt.println("[5] try_lock spin + yield stress...");
    i64 tl_mtx = thread.mutex();
    i64 tl_counter = atomic.new(i64(0));

    i64 t8 = time.now_ms();

    i64 tl_handles = atomic.new(i64(0));
    for (i64 i = i64(1); i < TRYLOCK_THREADS; i = i + i64(1)) {
        atomic.new(i64(0));
    }
    for (i64 i = i64(0); i < TRYLOCK_THREADS; i = i + i64(1)) {
        i64 iters = TRYLOCK_ITERS;
        i64 t = thread.spawn(fn() -> void {
            trylock_worker(tl_mtx, tl_counter, iters);
        });
        atomic.store(tl_handles + i, t);
    }
    for (i64 i = i64(0); i < TRYLOCK_THREADS; i = i + i64(1)) {
        thread.join(atomic.load(tl_handles + i));
    }

    i64 t9 = time.now_ms();
    i64 tl_ms = t9 - t8;
    i64 tl_result = atomic.load(tl_counter);
    i64 tl_expected = TRYLOCK_THREADS * TRYLOCK_ITERS;
    fmt.println(f"    Counter: {tl_result} (expected: {tl_expected})");
    fmt.println(f"    Time: {tl_ms} ms");
    if (tl_result != tl_expected) {
        fmt.println("    *** FAIL: try_lock counter mismatch ***");
    }

    // ── Section 6: CAS-based lock-free counter ──────────────────────────
    fmt.println("");
    fmt.println("[6] CAS lock-free counter...");
    i64 cas_counter = atomic.new(i64(0));

    i64 t10 = time.now_ms();

    i64 cas_handles = atomic.new(i64(0));
    for (i64 i = i64(1); i < CAS_THREADS; i = i + i64(1)) {
        atomic.new(i64(0));
    }
    for (i64 i = i64(0); i < CAS_THREADS; i = i + i64(1)) {
        i64 iters = CAS_ITERS;
        i64 t = thread.spawn(fn() -> void {
            cas_worker(cas_counter, iters);
        });
        atomic.store(cas_handles + i, t);
    }
    for (i64 i = i64(0); i < CAS_THREADS; i = i + i64(1)) {
        thread.join(atomic.load(cas_handles + i));
    }

    i64 t11 = time.now_ms();
    i64 cas_ms = t11 - t10;
    i64 cas_result = atomic.load(cas_counter);
    i64 cas_expected = CAS_THREADS * CAS_ITERS;
    fmt.println(f"    Counter: {cas_result} (expected: {cas_expected})");
    fmt.println(f"    Time: {cas_ms} ms");
    if (cas_result != cas_expected) {
        fmt.println("    *** FAIL: CAS counter mismatch ***");
    }

    // ── Section 7: Broadcast barrier emulation ──────────────────────────
    fmt.println("");
    fmt.println(f"[7] Broadcast barrier ({BROADCAST_THREADS} threads)...");
    i64 bar_mtx = thread.mutex();
    i64 bar_cond = thread.cond();
    i64 bar_arrived = atomic.new(i64(0));
    i64 bar_total = atomic.new(BROADCAST_THREADS);
    i64 bar_result = atomic.new(i64(0));

    i64 t12 = time.now_ms();

    i64 bar_handles = atomic.new(i64(0));
    for (i64 i = i64(1); i < BROADCAST_THREADS; i = i + i64(1)) {
        atomic.new(i64(0));
    }
    for (i64 i = i64(0); i < BROADCAST_THREADS; i = i + i64(1)) {
        i64 t = thread.spawn(fn() -> void {
            barrier_worker(bar_mtx, bar_cond, bar_arrived, BROADCAST_THREADS, bar_result);
        });
        atomic.store(bar_handles + i, t);
    }
    for (i64 i = i64(0); i < BROADCAST_THREADS; i = i + i64(1)) {
        thread.join(atomic.load(bar_handles + i));
    }

    i64 t13 = time.now_ms();
    i64 bar_ms = t13 - t12;
    i64 bar_count = atomic.load(bar_result);
    fmt.println(f"    Threads past barrier: {bar_count} (expected: {BROADCAST_THREADS})");
    fmt.println(f"    Time: {bar_ms} ms");
    if (bar_count != BROADCAST_THREADS) {
        fmt.println("    *** FAIL: not all threads passed barrier ***");
    }

    // ── Section 8: Summary ──────────────────────────────────────────────
    fmt.println("");
    fmt.println("=== Summary ===");
    i64 failures = i64(0);

    // Check pi estimates are in the right ballpark (within 5%)
    // pi ~= 4 * hits / total_iters, so hits ~= total_iters * pi / 4
    // Expected hits ~= total_iters * 0.785 (for our integer grid method)
    // We just check sequential and parallel are both > 0 and reasonably close
    if (seq_hits == i64(0)) {
        fmt.println("FAIL: Sequential hits = 0");
        failures = failures + i64(1);
    }
    if (par_result == i64(0)) {
        fmt.println("FAIL: Parallel hits = 0");
        failures = failures + i64(1);
    }

    if (total_consumed != total_produced) {
        fmt.println("FAIL: Producer-consumer count mismatch");
        failures = failures + i64(1);
    }
    if (total_sum != expected_sum) {
        fmt.println("FAIL: Producer-consumer sum mismatch");
        failures = failures + i64(1);
    }
    if (final_shared != expected_writes) {
        fmt.println("FAIL: RWLock write count mismatch");
        failures = failures + i64(1);
    }
    if (tl_result != tl_expected) {
        fmt.println("FAIL: try_lock counter mismatch");
        failures = failures + i64(1);
    }
    if (cas_result != cas_expected) {
        fmt.println("FAIL: CAS counter mismatch");
        failures = failures + i64(1);
    }
    if (bar_count != BROADCAST_THREADS) {
        fmt.println("FAIL: Barrier count mismatch");
        failures = failures + i64(1);
    }

    if (failures == i64(0)) {
        fmt.println("ALL CHECKS PASSED");
    } else {
        fmt.println(f"{failures} CHECK(S) FAILED");
    }

    // Thread count: 50 (MC) + 8 (prod) + 8 (cons) + 14 (rw) + 8 (trylock)
    //             + 16 (cas) + 20 (barrier) = 124 total threads spawned
    i64 total_threads = NUM_WORKERS + NUM_PRODUCERS + NUM_CONSUMERS
                      + RW_READERS + RW_WRITERS + TRYLOCK_THREADS
                      + CAS_THREADS + BROADCAST_THREADS;
    fmt.println(f"Total threads spawned: {total_threads}");

    i64 total_ms = time.now_ms() - t0;
    fmt.println(f"Total wall time: {total_ms} ms");

    if (failures > i64(0)) {
        return 1;
    }
    return 0;
}
