import "test";
import "os";
import "file";

// Note: Tests use sh for stdin redirection, which requires Unix-like shell.
// Windows users should run tests in WSL, Git Bash, or similar environment.

fn test_sort_basic(test.T t) -> void {
    file.write_all("test_sort_in.txt", "zebra\napple\nbanana\n");
    
    string out, string errs, i32 exitCode, err e = os.exec("sh", "-c", "./basl examples/basl-sort/main.basl < test_sort_in.txt");
    t.assert(string(e) == "ok", "sort should exit 0");
    t.assert(out == "apple\nbanana\nzebra\n", "should sort lines alphabetically");
    
    file.remove("test_sort_in.txt");
}

fn main() -> i32 {
    return 0;
}
