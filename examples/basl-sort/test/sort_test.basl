import "t";
import "os";
import "file";

fn test_sort_basic() -> void {
    os.exec("sh", "-c", "printf 'zebra\\napple\\nbanana\\n' > /tmp/basl_sort_in.txt");
    
    string out, string errs, err e = os.exec("sh", "-c", "./basl examples/basl-sort/main.basl < /tmp/basl_sort_in.txt");
    t.assert(string(e) == "ok", "sort should exit 0");
    t.assert(out == "apple\nbanana\nzebra\n", "should sort lines alphabetically");
}

fn main() -> i32 {
    return 0;
}
