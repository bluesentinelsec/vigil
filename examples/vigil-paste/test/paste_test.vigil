import "test";
import "os";
import "file";

// Note: Tests require file I/O which is cross-platform.

fn test_paste_two_files(test.T t) -> void {
    file.write_all("test_paste_f1.txt", "a\nb\nc\n");
    file.write_all("test_paste_f2.txt", "1\n2\n3\n");
    
    string out, string errs, i32 exitCode, err e = os.exec("./vigil", "examples/vigil-paste/main.vigil", "test_paste_f1.txt", "test_paste_f2.txt");
    t.assert(string(e) == "ok", "paste should exit 0");
    t.assert(out == "a\t1\nb\t2\nc\t3\n", "should merge lines with tabs");
    
    file.remove("test_paste_f1.txt");
    file.remove("test_paste_f2.txt");
}

fn test_paste_single_file(test.T t) -> void {
    file.write_all("test_paste_single.txt", "a\nb\nc\n");
    
    string out, string errs, i32 exitCode, err e = os.exec("./vigil", "examples/vigil-paste/main.vigil", "test_paste_single.txt");
    t.assert(string(e) == "ok", "paste with single file should exit 0");
    t.assert(out == "a\nb\nc\n", "single file should pass through unchanged");
    
    file.remove("test_paste_single.txt");
}

fn main() -> i32 {
    return 0;
}
