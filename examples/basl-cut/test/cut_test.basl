import "t";
import "os";
import "file";

fn test_cut_basic() -> void {
    os.exec("sh", "-c", "printf 'a:b:c\\nd:e:f' > /tmp/basl_cut_in.txt");
    
    string out, string errs, err e = os.exec("sh", "-c", "./basl examples/basl-cut/main.basl --f 2 --d : < /tmp/basl_cut_in.txt > /tmp/basl_cut_out.txt");
    t.assert(string(e) == "ok", "cut should exit 0");
    
    string output, err e2 = file.read_all("/tmp/basl_cut_out.txt");
    t.assert(output.contains("b"), "should extract field 2");
}

fn test_cut_invalid_field() -> void {
    os.exec("sh", "-c", "echo 'a:b:c' > /tmp/basl_cut_invalid.txt");
    
    string out, string errs, err e = os.exec("sh", "-c", "./basl examples/basl-cut/main.basl --f x2 --d : < /tmp/basl_cut_invalid.txt 2>&1");
    t.assert(string(e) != "ok", "cut should reject invalid field spec");
}

fn main() -> i32 {
    return 0;
}
