import "t";
import "os";

fn test_cut_basic() -> void {
    os.exec("sh", "-c", "printf 'a:b:c\\nd:e:f\\n' > /tmp/basl_cut_in.txt");
    
    string out, string errs, err e = os.exec("sh", "-c", "./basl examples/basl-cut/main.basl --f 2 --d : < /tmp/basl_cut_in.txt");
    t.assert(string(e) == "ok", "cut should exit 0");
    t.assert(out == "b\ne\n", "should extract field 2 from both lines");
}

fn test_cut_invalid_field() -> void {
    string out, string errs, err e = os.exec("sh", "-c", "./basl examples/basl-cut/main.basl --f x2 --d : < /dev/null 2>&1");
    t.assert(string(e) != "ok", "cut should reject invalid field spec");
}

fn main() -> i32 {
    return 0;
}
