import "t";
import "os";
import "file";

// Note: Tests use sh for stdin redirection, which requires Unix-like shell.
// Windows users should run tests in WSL, Git Bash, or similar environment.

fn test_cut_basic() -> void {
    file.write_all("test_cut_in.txt", "a:b:c\nd:e:f\n");
    
    string out, string errs, i32 exitCode, err e = os.exec("sh", "-c", "./basl examples/basl-cut/main.basl --f 2 --d : < test_cut_in.txt");
    t.assert(string(e) == "ok", "cut should exit 0");
    t.assert(out == "b\ne\n", "should extract field 2 from both lines");
    
    file.remove("test_cut_in.txt");
}

fn test_cut_invalid_field() -> void {
    string out, string errs, i32 exitCode, err e = os.exec("sh", "-c", "echo '' | ./basl examples/basl-cut/main.basl --f x2 --d : 2>&1");
    t.assert(exitCode != 0, "cut should reject invalid field spec");
}

fn main() -> i32 {
    return 0;
}
