import "os";
import "file";
import "fmt";

fn main() -> i32 {
    array<string> args = os.args();
    
    if (args.len() == 0) {
        fmt.eprintln("vigil-touch: missing file operand");
        return 1;
    }
    
    for (i32 i = 0; i < args.len(); i++) {
        err e = file.touch(args[i]);
        if (e != ok) {
            fmt.eprintln(f"vigil-touch: {args[i]}: {e.message()}");
            return 1;
        }
    }
    
    return 0;
}
