    } else {
        fail_count = fail_count + 1;
    }

    if (run_progress_test()) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
    }

    if (run_number_format_test()) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
    }

    if (run_unicode_test()) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
    }

    if (run_fstring_edge_test()) {
        pass_count = pass_count + 1;
    } else {
