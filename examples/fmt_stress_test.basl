fn main() -> i32 {
    fmt.println("╔══════════════════════════════════════════════════════════╗");
    fmt.println("║       fmt Module Stress Test — BASL                     ║");
    fmt.println("╚══════════════════════════════════════════════════════════╝");
    i64 t_start = time.now_ms();
    i32 pass_count = 0;
    i32 fail_count = 0;
    if (run_table_test()) {
