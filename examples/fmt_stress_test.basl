// ══════════════════════════════════════════════════════════════════════════════
// BASL fmt Module Stress Test
//
// A multi-format report / log / diagnostic dumper that exercises every aspect
// of the fmt module (println, print, eprintln) and f-string formatting.
//
// Sections:
//   1. Pad/Align Helpers (manual — fmt has no width specifiers)
//   2. Table Formatter — aligned columnar output with borders
//   3. Log System — severity-leveled structured log lines
//   4. Tree Printer — nested structure pretty-printing
//   5. Progress Bar — dynamic progress visualization
//   6. Number Formatting — thousands separators, currency, percentages
//   7. Unicode & Emoji Stress — multi-byte chars, emoji sequences
//   8. F-String Edge Cases — special floats, precision, escaping, casts
//   9. High-Volume Stress — 100k formatted lines under load
//  10. Main Driver
// ══════════════════════════════════════════════════════════════════════════════
// ── Section 1: Pad / Align Helpers ──────────────────────────────────────────
// The fmt module has no width/alignment/fill specifiers. Every table, log, and
// report needs manual padding. This is the single biggest gap.
/// Pad string on the right to width with spaces.

import "fmt";
import "math";
import "time";

fn pad_right(string s, i32 width) -> string {
    i32 slen = s.len();
    if (slen >= width) {
        return s;
    }

    return s + " ".repeat(width - slen);
}
/// Pad string on the left to width with spaces.
fn pad_left(string s, i32 width) -> string {
    i32 slen = s.len();
    if (slen >= width) {
        return s;
    }

    return " ".repeat(width - slen) + s;
}
/// Center string within width.
fn center(string s, i32 width) -> string {
    i32 slen = s.len();
    if (slen >= width) {
        return s;
    }

    i32 total = width - slen;
    i32 lp = total / 2;
    return " ".repeat(lp) + s + " ".repeat(total - lp);
}
/// Pad string on the left with custom fill character.
fn pad_left_fill(string s, i32 width, string fill) -> string {
    i32 slen = s.len();
    if (slen >= width) {
        return s;
    }

    return fill.repeat(width - slen) + s;
}
/// Right-align an integer in a field.
fn pad_num(i64 n, i32 width) -> string {
    return pad_left(f"{n}", width);
}
/// Right-align a float with given precision in a field.
fn pad_f64(f64 n, i32 prec, i32 width) -> string {
    string s = "";
    if (prec == 0) {
        s = f"{n:.0f}";
    } else if (prec == 1) {
        s = f"{n:.1f}";
    } else if (prec == 2) {
        s = f"{n:.2f}";
    } else if (prec == 3) {
        s = f"{n:.3f}";
    } else if (prec == 4) {
        s = f"{n:.4f}";
    } else {
        s = f"{n:.6f}";
    }

    return pad_left(s, width);
}
// ── Section 2: Table Formatter ──────────────────────────────────────────────
// Aligned columnar output like database query results. Exercises pad helpers,
// f-string interpolation with expressions, string repeat, and concatenation.
fn print_table_sep(i32 c1, i32 c2, i32 c3, i32 c4) -> void {
    fmt.println("+" + "-".repeat(c1 + 2) + "+" + "-".repeat(c2 + 2) + "+" + "-".repeat(c3 + 2) + "+" + "-".repeat(c4 + 2) + "+");
}

fn run_table_test() -> bool {
    fmt.println("=== Section 2: Table Formatter ===");
    // Column widths
    i32 w1 = 4;
    i32 w2 = 20;
    i32 w3 = 10;
    i32 w4 = 12;
    // Header
    print_table_sep(w1, w2, w3, w4);
    string h_id = "ID";
    string h_name = "Name";
    string h_score = "Score";
    string h_status = "Status";
    string hdr = f"| {pad_right(h_id, w1)} | {pad_right(h_name, w2)} | {pad_right(h_score, w3)} | {pad_right(h_status, w4)} |";
    fmt.println(hdr);
    print_table_sep(w1, w2, w3, w4);
    // Data rows — exercises f-string with method calls, casts, arithmetic
    array<string> names = ["Alice Johnson", "Bob Smith", "Charlie Brown", "Diana Prince", "Eve Nakamura"];
    array<f64> scores = [98.7, 85.333, 100.0, 72.1, 91.456];
    array<string> statuses = ["PASS", "PASS", "PASS+HONORS", "REVIEW", "PASS"];
    i32 i = 0;
    for name in names {
        f64 score, err se = scores.get(i);
        string status, err ste = statuses.get(i);
        string row = f"| {pad_right(string(i + 1), w1)} | {pad_right(name, w2)} | {pad_f64(score, 2, w3)} | {pad_right(status, w4)} |";
        fmt.println(row);
        i = i + 1;
    }

    print_table_sep(w1, w2, w3, w4);
    // Summary row with computed average
    f64 total = 0.0;
    for s in scores {
        total = total + s;}

    f64 avg = total / f64(scores.len());
    string empty_s = "";
    string avg_label = "Average";
    string summary = f"| {pad_right(empty_s, w1)} | {pad_right(avg_label, w2)} | {pad_f64(avg, 2, w3)} | {pad_right(empty_s, w4)} |";
    fmt.println(summary);
    print_table_sep(w1, w2, w3, w4);
    // Verify: we produced 5 data rows + header + separators
    fmt.println(f"  Rows: {i}, Avg: {avg:.2f}");
    bool pass = i == 5;
    fmt.println(f"  {pass}");
    return pass;
}
// ── Section 3: Log System ───────────────────────────────────────────────────
// Structured log lines with severity, timestamp, source, and message.
// Exercises: f-string with multiple interpolations, pad helpers, time module,
// string concatenation, conditional formatting.
fn log_line(string level, string source, string msg) -> string {
    i64 now = time.now();
    string ts = time.format(now, "%H:%M:%S");
    string lvl = pad_right(level, 5);
    string src = pad_right(source, 12);
    return f"[{ts}] {lvl} {src} | {msg}";
}

fn run_log_test() -> bool {
    fmt.println("\n=== Section 3: Log System ===");
    // Generate structured log lines at different severity levels
    fmt.println(log_line("DEBUG", "http.server", "Listening on port 8080"));
    fmt.println(log_line("INFO", "http.server", "Request GET /api/users"));
    fmt.println(log_line("INFO", "db.query", f"SELECT * FROM users WHERE id={42}"));
    fmt.println(log_line("WARN", "db.pool", f"Connection pool at {95}% capacity"));
    fmt.println(log_line("ERROR", "http.server", "Request failed: 500 Internal Server Error"));
    fmt.println(log_line("DEBUG", "cache", f"Hit ratio: {0.847:.2f}, misses: {153}"));
    // Log with computed values
    i64 req_count = i64(15234);
    f64 avg_latency = 23.456;
    f64 p99_latency = 187.23;
    fmt.println(log_line("INFO", "metrics", f"requests={req_count} avg_ms={avg_latency:.1f} p99_ms={p99_latency:.1f}"));
    // Multi-field structured log
    string method = "POST";
    string path = "/api/orders";
    i32 status_code = 201;
    f64 duration = 45.678;
    string log_msg = f"method={method} path={path} status={status_code} duration_ms={duration:.2f}";
    fmt.println(log_line("INFO", "http.access", log_msg));
    fmt.println(f"  Generated 8 log lines");
    return true;
}
// ── Section 4: Tree Printer ─────────────────────────────────────────────────
// Pretty-prints a nested directory/object tree structure.
// Exercises: recursion-like patterns, string repeat for indentation,
// f-string with conditional prefixes, deep string concatenation chains.
fn tree_line(i32 depth, bool is_last, string name, string detail) -> string {
    string indent = "";
    if (depth > 0) {
        indent = "  ".repeat(depth - 1);
        if (is_last) {
            indent = indent + "  └── ";
        } else {
            indent = indent + "  ├── ";
        }
    }

    if (detail.len() > 0) {
        return f"{indent}{name} ({detail})";
    }

    return f"{indent}{name}";
}

fn run_tree_test() -> bool {
    fmt.println("\n=== Section 4: Tree Printer ===");
    // Simulate a project directory tree
    fmt.println(tree_line(0, false, "project/", ""));
    fmt.println(tree_line(1, false, "src/", "4 files"));
    fmt.println(tree_line(2, false, "main.basl", f"{1234} bytes"));
    fmt.println(tree_line(2, false, "lib.basl", f"{5678} bytes"));
    fmt.println(tree_line(2, false, "utils.basl", f"{901} bytes"));
    fmt.println(tree_line(2, true, "config.basl", f"{234} bytes"));
    fmt.println(tree_line(1, false, "tests/", "2 files"));
    fmt.println(tree_line(2, false, "test_main.basl", f"{2345} bytes"));
    fmt.println(tree_line(2, true, "test_utils.basl", f"{1567} bytes"));
    fmt.println(tree_line(1, false, "docs/", "1 file"));
    fmt.println(tree_line(2, true, "README.md", f"{4096} bytes"));
    fmt.println(tree_line(1, true, "basl.toml", f"{128} bytes"));
    // Deeper nesting — 5 levels
    fmt.println("");
    fmt.println(tree_line(0, false, "deep/", ""));
    fmt.println(tree_line(1, false, "a/", ""));
    fmt.println(tree_line(2, false, "b/", ""));
    fmt.println(tree_line(3, false, "c/", ""));
    fmt.println(tree_line(4, false, "d/", ""));
    fmt.println(tree_line(5, true, "leaf.txt", f"{42} bytes"));
    fmt.println(f"  Tree rendered with 5 levels of nesting");
    return true;
}
// ── Section 5: Progress Bar ─────────────────────────────────────────────────
// Dynamic progress visualization using fmt.print (no newline) and \r.
// Exercises: fmt.print, string repeat, f-string with arithmetic, carriage return.
fn progress_bar(i32 current, i32 total, i32 bar_width) -> string {
    f64 ratio = f64(current) / f64(total);
    i32 filled = i32(ratio * f64(bar_width));
    if (filled > bar_width) {
        filled = bar_width;
    }

    i32 empty = bar_width - filled;
    f64 pct = ratio * 100.0;
    string bar = "[" + "#".repeat(filled) + "-".repeat(empty) + "]";
    return f"{bar} {pct:.1f}% ({current}/{total})";
}

fn run_progress_test() -> bool {
    fmt.println("\n=== Section 5: Progress Bar ===");
    // Show progress at key milestones (not animated — just snapshots)
    array<i32> milestones = [0, 10, 25, 50, 75, 90, 100];
    for pct in milestones {
        i32 current = pct * 500 / 100; fmt.println(f"  {progress_bar(current, 500, 30)}");
    }
    // Verify bar at 100%
    string full = progress_bar(500, 500, 30);
    bool has_100 = full.contains("100.0%");
    fmt.println(f"  Full bar contains 100.0%: {has_100}");
    return has_100;
}
// ── Section 6: Number Formatting ────────────────────────────────────────────
// Thousands separators, currency, percentages — all manual since fmt has none.
/// Format an integer with thousands separators.
fn fmt_thousands(i64 n) -> string {
    bool neg = n < i64(0);
    if (neg) {
        n = - n;
    }

    string s = string(n);
    i32 slen = s.len();
    if (slen <= 3) {
        if (neg) {
            return "-" + s;
        }

        return s;
    }

    string result = "";
    i32 count = 0;
    i32 idx = slen - 1;
    while (idx >= 0) {
        string ch, err e = s.char_at(idx);
        if (count > 0 && count % 3 == 0) {
            result = "," + result;
        }

        result = ch + result;
        count = count + 1;
        idx = idx - 1;
    }

    if (neg) {
        return "-" + result;
    }

    return result;
}
/// Format as currency (USD).
fn fmt_currency(f64 amount) -> string {
    bool neg = amount < 0.0;
    if (neg) {
        amount = - amount;
    }

    string cents = f"{amount:.2f}";
    // Split on decimal
    array<string> parts = cents.split(".");
    string whole, err e1 = parts.get(0);
    string frac, err e2 = parts.get(1);
    i64 w = i64(0);
    i64 ww, err e3 = parse_i64_simple(whole);
    w = ww;
    string formatted = fmt_thousands(w) + "." + frac;
    if (neg) {
        return "-$" + formatted;
    }

    return "$" + formatted;
}
/// Simple i64 parse (since parse module takes string).
fn parse_i64_simple(string s) -> (i64, err) {
    i64 result = i64(0);
    i32 i = 0;
    i32 slen = s.len();
    while (i < slen) {
        string ch, err e = s.char_at(i);
        i64 digit = i64(0);
        if (ch == "0") {
            digit = i64(0);
        } else if (ch == "1") {
            digit = i64(1);
        } else if (ch == "2") {
            digit = i64(2);
        } else if (ch == "3") {
            digit = i64(3);
        } else if (ch == "4") {
            digit = i64(4);
        } else if (ch == "5") {
            digit = i64(5);
        } else if (ch == "6") {
            digit = i64(6);
        } else if (ch == "7") {
            digit = i64(7);
        } else if (ch == "8") {
            digit = i64(8);
        } else if (ch == "9") {
            digit = i64(9);
        }

        result = result * i64(10) + digit;
        i = i + 1;
    }

    return (result, ok);
}
/// Format as percentage.
fn fmt_pct(f64 ratio) -> string {
    f64 pct = ratio * 100.0;
    return f"{pct:.1f}%";
}

fn run_number_format_test() -> bool {
    fmt.println("\n=== Section 6: Number Formatting ===");
    // Thousands separators
    fmt.println(f"  {fmt_thousands(i64(0))}");
    fmt.println(f"  {fmt_thousands(i64(999))}");
    fmt.println(f"  {fmt_thousands(i64(1000))}");
    fmt.println(f"  {fmt_thousands(i64(1234567))}");
    fmt.println(f"  {fmt_thousands(9999999999)}");
    fmt.println(f"  {fmt_thousands(i64(-42000))}");
    // Currency
    fmt.println(f"  {fmt_currency(0.0)}");
    fmt.println(f"  {fmt_currency(9.99)}");
    fmt.println(f"  {fmt_currency(1234.56)}");
    fmt.println(f"  {fmt_currency(1000000.0)}");
    fmt.println(f"  {fmt_currency(-500.75)}");
    // Percentages
    fmt.println(f"  {fmt_pct(0.0)}");
    fmt.println(f"  {fmt_pct(0.5)}");
    fmt.println(f"  {fmt_pct(1.0)}");
    fmt.println(f"  {fmt_pct(0.123456)}");
    // Verify specific values
    bool ok = fmt_thousands(i64(1234567)) == "1,234,567";
    ok = ok && fmt_currency(1234.56) == "$1,234.56";
    ok = ok && fmt_pct(0.5) == "50.0%";
    fmt.println(f"  Verification: {ok}");
    return ok;
}
// ── Section 7: Unicode & Emoji Stress ───────────────────────────────────────
// Tests multi-byte characters, emoji, combining marks, and CJK in f-strings.
// Key question: does .len() return bytes or characters? (Answer: bytes.)
// Does padding break with multi-byte chars? (Answer: yes, since pad uses .len().)
fn run_unicode_test() -> bool {
    fmt.println("\n=== Section 7: Unicode & Emoji Stress ===");
    // Basic emoji
    string rocket = "🚀";
    string flag = "🇺🇸";
    string family = "👨‍👩‍👧‍👦";
    string wave = "👋🏽";
    fmt.println(f"  rocket: {rocket} len={rocket.len()}");
    fmt.println(f"  flag:   {flag} len={flag.len()}");
    fmt.println(f"  family: {family} len={family.len()}");
    fmt.println(f"  wave:   {wave} len={wave.len()}");
    // CJK characters
    string cjk = "你好世界";
    fmt.println(f"  CJK:    {cjk} len={cjk.len()}");
    // Accented characters
    string accent = "café";
    fmt.println(f"  accent: {accent} len={accent.len()}");
    // Mixed ASCII and emoji in f-string
    i32 count = 42;
    fmt.println(f"  Status: {rocket} Launched {count} missions {rocket}");
    // Emoji in repeated strings
    string stars = "⭐".repeat(5);
    fmt.println(f"  stars:  {stars}");
    // Unicode in table alignment (demonstrates the byte-length problem)
    string ascii_w = "hello";
    string accent_w = accent;
    string cjk_w = "AB";
    string emoji_w = rocket + rocket;
    fmt.println(f"  Alignment test (byte-based .len() breaks visual alignment):");
    fmt.println(f"    |{pad_right(ascii_w, 10)}| <- ASCII, 5 chars, 5 bytes");
    fmt.println(f"    |{pad_right(accent_w, 10)}| <- accented, 4 chars, 5 bytes");
    fmt.println(f"    |{pad_right(cjk_w, 10)}| <- CJK ref, 2 chars");
    fmt.println(f"    |{pad_right(emoji_w, 10)}| <- emoji, 2 chars, 8 bytes");
    // String operations on unicode
    bool has_cafe = "I love café".contains("café");
    string upper_cjk = cjk.to_upper();
    fmt.println(f"  contains café: {has_cafe}");
    fmt.println(f"  CJK to_upper: {upper_cjk}");
    // Very long unicode string
    string long_emoji = "🎉".repeat(100);
    fmt.println(f"  100 party emojis len: {long_emoji.len()}");
    fmt.println(f"  Unicode tests complete");
    return true;
}
// ── Section 8: F-String Edge Cases ──────────────────────────────────────────
// Pushes f-string parsing and formatting to its limits.
fn run_fstring_edge_test() -> bool {
    fmt.println("\n=== Section 8: F-String Edge Cases ===");
    bool ok = true;
    // 1. Empty f-string
    string empty = f"";
    string empty_ref = "";
    bool empty_ok = empty == empty_ref;
    ok = ok && empty_ok;
    fmt.println(f"  empty f-string: [{empty}] ok={empty_ok}");
    // 2. F-string with no interpolation (just literal text)
    string literal = f"just text";
    ok = ok && literal == "just text";
    fmt.println(f"  literal f-string: [{literal}]");
    // 3. Escaped braces
    string braces = f"{{curly}}";
    fmt.println(f"  escaped braces: [{braces}]");
    ok = ok && braces == "{curly}";
    // 4. Adjacent interpolations
    i32 a = 1;
    i32 b = 2;
    string adjacent = f"{a}{b}";
    ok = ok && adjacent == "12";
    fmt.println(f"  adjacent: [{adjacent}]");
    // 5. Interpolation at start and end
    string at_start = f"{a} hello";
    string at_end = f"hello {b}";
    fmt.println(f"  at_start: [{at_start}] at_end: [{at_end}]");
    // 6. Complex expressions
    i32 x = 10;
    string complex = f"result={x * x + x / 2 - 1}";
    fmt.println(f"  complex expr: [{complex}]");
    // 7. Method calls in interpolation
    string name = "  alice  ";
    string method_call = f"[{name.trim().to_upper()}]";
    ok = ok && method_call == "[ALICE]";
    fmt.println(f"  method call: {method_call}");
    // 8. Boolean interpolation
    bool t = true;
    bool f2 = false;
    string bools = f"{t} and {f2}";
    ok = ok && bools == "true and false";
    fmt.println(f"  bools: [{bools}]");
    // 9. Special float values
    f64 inf_val = 1.0 / 0.0;
    f64 neg_inf = - 1.0 / 0.0;
    f64 nan_val = 0.0 / 0.0;
    fmt.println(f"  inf: [{inf_val}]");
    fmt.println(f"  -inf: [{neg_inf}]");
    fmt.println(f"  nan: [{nan_val}]");
    // 10. Special floats with precision
    fmt.println(f"  inf:.2f: [{inf_val:.2f}]");
    fmt.println(f"  nan:.2f: [{nan_val:.2f}]");
    // 11. Precision extremes
    f64 pi = 3.14159265358979;
    fmt.println(f"  pi:.0f: [{pi:.0f}]");
    fmt.println(f"  pi:.1f: [{pi:.1f}]");
    fmt.println(f"  pi:.10f: [{pi:.10f}]");
    fmt.println(f"  pi:.20f: [{pi:.20f}]");
    // 12. Very small float
    f64 tiny = 0.000000001;
    fmt.println(f"  tiny: [{tiny}]");
    fmt.println(f"  tiny:.15f: [{tiny:.15f}]");
    // 13. Very large float
    f64 huge = 99999999999999.99;
    fmt.println(f"  huge: [{huge}]");
    fmt.println(f"  huge:.2f: [{huge:.2f}]");
    // 14. Negative zero
    f64 neg_zero = - 0.0;
    fmt.println(f"  -0.0: [{neg_zero}]");
    fmt.println(f"  -0.0:.2f: [{neg_zero:.2f}]");
    // 15. string() cast in f-string
    string cast_i = f"cast_i={string(42)}";
    string cast_f = f"cast_f={string(3.14)}";
    string cast_b = f"cast_b={string(true)}";
    fmt.println(f"  {cast_i}");
    fmt.println(f"  {cast_f}");
    fmt.println(f"  {cast_b}");
    // 16. i64 max/min
    i64 max_i64 = 9223372036854775807;
    fmt.println(f"  i64 max: [{max_i64}]");
    // 17. Nested f-string (f-string result used in another f-string)
    string inner = f"inner={x}";
    string outer = f"outer=[{inner}]";
    fmt.println(f"  nested: {outer}");
    // 18. Long interpolated string
    string long_val = "x".repeat(1000);
    string long_fstr = f"long=[{long_val}]";
    ok = ok && long_fstr.len() == 1007;
    fmt.println(f"  long f-string len: {long_fstr.len()}");
    // 19. Many interpolations in one f-string
    i32 v1 = 1;
    i32 v2 = 2;
    i32 v3 = 3;
    i32 v4 = 4;
    i32 v5 = 5;
    string many = f"{v1}-{v2}-{v3}-{v4}-{v5}";
    ok = ok && many == "1-2-3-4-5";
    fmt.println(f"  many interps: [{many}]");
    // 20. Escape sequences in f-string
    string with_tab = f"col1\tcol2\tcol3";
    string with_nl = f"line1\nline2";
    fmt.println(f"  tab: [{with_tab}]");
    fmt.println(f"  newline embedded (len={with_nl.len()})");
    fmt.println(f"  Edge case verification: {ok}");
    return ok;
}
// ── Section 9: High-Volume Stress ───────────────────────────────────────────
// Formats 100,000 lines to test performance and memory behavior.
// Exercises: tight loop with f-string, string concatenation, pad helpers.
fn run_volume_test() -> bool {
    fmt.println("\n=== Section 9: High-Volume Stress ===");
    i64 t_start = time.now_ms();
    // Phase 1: 50,000 f-string formatted log lines (not printed — just built)
    i32 count1 = 50000;
    i32 i = 0;
    i64 total_len = i64(0);
    string zero_fill = "0";
    while (i < count1) {
        string line = f"[{pad_left_fill(string(i), 6, zero_fill)}] level=INFO msg=request_processed latency_ms={f64(i % 1000):.2f} status=200";
        total_len = total_len + i64(line.len());
        i = i + 1;
    }

    i64 t_phase1 = time.now_ms() - t_start;
    fmt.println(f"  Phase 1: {count1} log lines built, total bytes={total_len}, time={t_phase1}ms");
    // Phase 2: 50,000 table row strings
    i64 t2 = time.now_ms();
    i32 count2 = 50000;
    i = 0;
    i64 total_len2 = i64(0);
    while (i < count2) {
        string item_name = "item_" + string(i);
        string row = f"| {pad_num(i64(i), 8)} | {pad_right(item_name, 20)} | {pad_f64(f64(i) * 0.01, 2, 10)} |";
        total_len2 = total_len2 + i64(row.len());
        i = i + 1;
    }

    i64 t_phase2 = time.now_ms() - t2;
    fmt.println(f"  Phase 2: {count2} table rows built, total bytes={total_len2}, time={t_phase2}ms");
    i64 t_total = time.now_ms() - t_start;
    i64 total_lines = i64(count1 + count2);
    fmt.println(f"  Total: {total_lines} lines, {total_len + total_len2} bytes, {t_total}ms");
    // Sanity check: total_len should be reasonable
    bool ok = total_len > i64(0) && total_len2 > i64(0);
    fmt.println(f"  Volume test: {ok}");
    return ok;
}
