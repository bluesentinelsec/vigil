    }

    if (run_volume_test()) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
    }

    i64 t_total = time.now_ms() - t_start;
    fmt.println("\n══════════════════════════════════════════════════════════");
    fmt.println(f"  Results: {pass_count} passed, {fail_count} failed");
    fmt.println(f"  Total time: {t_total}ms");
