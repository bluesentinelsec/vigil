// Main
// ============================================================================
fn main() -> i32 {
    fmt.println("╔══════════════════════════════════════════════════════════╗");
    fmt.println("║       Atomic Module Stress Test — BASL                  ║");
    fmt.println("╚══════════════════════════════════════════════════════════╝");
    fmt.println("");
    i64 t_start = time.now_ms();
    i32 pass_count = 0;
    i32 fail_count = 0;
    if (run_ring_buffer_test()) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
    }

    if (run_metrics_test()) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
    }

    if (run_spinlock_test()) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
    }

    if (run_stack_test()) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
    }

    if (run_barrier_test()) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
    }

    if (run_mutex_reference_test()) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
    }

    i64 t_total = time.now_ms() - t_start;
    fmt.println("══════════════════════════════════════════════════════════");
    fmt.println(f"  Results: {pass_count} passed, {fail_count} failed");
    fmt.println(f"  Total time: {t_total}ms");
    // Summary of atomic operations exercised:
    // - atomic.new:   ring buffer slots, metrics shards, spinlock, stack pool, barrier, mutex ref
    // - atomic.load:  ring buffer seq/val reads, metrics reads, spinlock check, stack top, barrier
    // - atomic.store: ring buffer seq/val writes, spinlock release, stack node setup, barrier flag
    // - atomic.add:   metrics counters, consumed totals, push/pop sums
    // - atomic.sub:   barrier countdown
    // - atomic.cas:   ring buffer head/tail, metrics gauge CAS, spinlock acquire, stack push/pop
    // - atomic.inc:   ring buffer enq/deq counts, metrics ops, spinlock contention, barrier result
    // - atomic.dec:   (available but inc/sub cover the same ground)
    if (fail_count > 0) {
        fmt.println("  STATUS: FAIL");
        return 1;
    }

    fmt.println("  STATUS: ALL PASS");
    fmt.println("══════════════════════════════════════════════════════════");
    return 0;
}
