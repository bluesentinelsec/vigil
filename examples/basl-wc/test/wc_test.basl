import "t";
import "file";
import "os";

fn get_temp_path(string filename) -> string {
    string platform = os.platform();
    if (platform == "windows") {
        return "C:\\Windows\\Temp\\" + filename;
    }
    return "/tmp/" + filename;
}

fn find_basl_and_main() -> (string, string) {
    if (file.exists("basl") && file.exists("examples/basl-wc/main.basl")) {
        return ("./basl", "examples/basl-wc/main.basl");
    }
    if (file.exists("../../basl") && file.exists("main.basl")) {
        return ("../../basl", "main.basl");
    }
    return ("", "");
}

fn test_wc_single_file() -> void {
    string basl_bin, string main_script = find_basl_and_main();
    t.assert(basl_bin != "", "should find basl binary");
    
    string test_file = get_temp_path("basl_wc_test1.txt");
    string content = "line one\nline two\nline three\n";
    err e = file.write_all(test_file, content);
    t.assert(e == ok, "should write test file");
    
    string stdout, string stderr, err e2 = os.exec(basl_bin, main_script, test_file);
    t.assert(e2 == ok, "basl-wc should succeed");
    t.assert(stdout.contains("3 "), "should show 3 lines");
    t.assert(stdout.contains("6 "), "should show 6 words");
    t.assert(stdout.contains("29 "), "should show 29 bytes");
    
    file.remove(test_file);
}

fn test_wc_multiple_files() -> void {
    string basl_bin, string main_script = find_basl_and_main();
    t.assert(basl_bin != "", "should find basl binary");
    
    string file1 = get_temp_path("basl_wc_test2a.txt");
    string file2 = get_temp_path("basl_wc_test2b.txt");
    
    err e1 = file.write_all(file1, "one\n");
    err e2 = file.write_all(file2, "two\n");
    t.assert(e1 == ok && e2 == ok, "should write test files");
    
    string stdout, string stderr, err e3 = os.exec(basl_bin, main_script, file1, file2);
    t.assert(e3 == ok, "basl-wc should succeed");
    t.assert(stdout.contains("total"), "should show total line");
    t.assert(stdout.contains("2 "), "total should show 2 lines");
    
    file.remove(file1);
    file.remove(file2);
}

fn test_wc_lines_only() -> void {
    string basl_bin, string main_script = find_basl_and_main();
    t.assert(basl_bin != "", "should find basl binary");
    
    string test_file = get_temp_path("basl_wc_test3.txt");
    err e = file.write_all(test_file, "a\nb\nc\n");
    t.assert(e == ok, "should write test file");
    
    string stdout, string stderr, err e2 = os.exec(basl_bin, main_script, "-l", test_file);
    t.assert(e2 == ok, "basl-wc -l should succeed");
    t.assert(stdout.contains("3 "), "should show 3 lines");
    t.assert(!stdout.contains(" 3 "), "should not show words (no double space before 3)");
    t.assert(!stdout.contains(" 6 "), "should not show bytes");
    
    file.remove(test_file);
}

fn test_wc_empty_file() -> void {
    string basl_bin, string main_script = find_basl_and_main();
    t.assert(basl_bin != "", "should find basl binary");
    
    string test_file = get_temp_path("basl_wc_empty.txt");
    err e = file.write_all(test_file, "");
    t.assert(e == ok, "should write empty file");
    
    string stdout, string stderr, err e2 = os.exec(basl_bin, main_script, test_file);
    t.assert(e2 == ok, "basl-wc should succeed on empty file");
    t.assert(stdout.contains("0 0 0"), "should show all zeros");
    
    file.remove(test_file);
}
