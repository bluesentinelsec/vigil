import "fmt";
import "readline";

fn main() -> i32 {
    string prev = "";
    bool first = true;

    string line = readline.input("");
    while (!line.is_empty()) {
        if (first || line != prev) {
            fmt.println(line);
            prev = line;
            first = false;
        }
        line = readline.input("");
    }

    return 0;
}
