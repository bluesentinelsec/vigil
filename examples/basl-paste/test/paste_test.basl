import "t";
import "os";

fn test_paste_two_files() -> void {
    os.exec("sh", "-c", "printf 'a\\nb\\nc\\n' > /tmp/basl_paste_f1.txt");
    os.exec("sh", "-c", "printf '1\\n2\\n3\\n' > /tmp/basl_paste_f2.txt");
    
    string out, string errs, err e = os.exec("sh", "-c", "./basl examples/basl-paste/main.basl /tmp/basl_paste_f1.txt /tmp/basl_paste_f2.txt");
    t.assert(string(e) == "ok", "paste should exit 0");
    t.assert(out.contains("a\t1"), "should merge lines");
}

fn test_paste_single_file() -> void {
    os.exec("sh", "-c", "printf 'a\\nb\\nc\\n' > /tmp/basl_paste_single.txt");
    
    string out, string errs, err e = os.exec("sh", "-c", "./basl examples/basl-paste/main.basl /tmp/basl_paste_single.txt");
    t.assert(string(e) == "ok", "paste with single file should exit 0");
    t.assert(out.contains("a"), "should contain input");
}

fn main() -> i32 {
    return 0;
}
