import "test";
import "file";
import "os";

fn get_temp_path(string filename) -> string {
    string platform = os.platform();
    if (platform == "windows") {
        return "C:\\Windows\\Temp\\" + filename;
    }
    return "/tmp/" + filename;
}

fn find_vigil_and_main() -> (string, string) {
    if (file.exists("vigil") && file.exists("examples/vigil-wc/main.vigil")) {
        return ("./vigil", "examples/vigil-wc/main.vigil");
    }
    if (file.exists("../../vigil") && file.exists("main.vigil")) {
        return ("../../vigil", "main.vigil");
    }
    return ("", "");
}

fn test_wc_single_file(test.T t) -> void {
    string vigil_bin, string main_script = find_vigil_and_main();
    t.assert(vigil_bin != "", "should find vigil binary");
    
    string test_file = get_temp_path("vigil_wc_test1.txt");
    string content = "line one\nline two\nline three\n";
    err e = file.write_all(test_file, content);
    t.assert(e == ok, "should write test file");
    
    string stdout, string stderr, i32 exitCode, err e2 = os.exec(vigil_bin, main_script, test_file);
    t.assert(e2 == ok, "vigil-wc should succeed");
    t.assert(stdout.contains("3 "), "should show 3 lines");
    t.assert(stdout.contains("6 "), "should show 6 words");
    t.assert(stdout.contains("29 "), "should show 29 bytes");
    
    file.remove(test_file);
}

fn test_wc_multiple_files(test.T t) -> void {
    string vigil_bin, string main_script = find_vigil_and_main();
    t.assert(vigil_bin != "", "should find vigil binary");
    
    string file1 = get_temp_path("vigil_wc_test2a.txt");
    string file2 = get_temp_path("vigil_wc_test2b.txt");
    
    err e1 = file.write_all(file1, "one\n");
    err e2 = file.write_all(file2, "two\n");
    t.assert(e1 == ok && e2 == ok, "should write test files");
    
    string stdout, string stderr, i32 exitCode, err e3 = os.exec(vigil_bin, main_script, file1, file2);
    t.assert(e3 == ok, "vigil-wc should succeed");
    t.assert(stdout.contains("total"), "should show total line");
    t.assert(stdout.contains("2 "), "total should show 2 lines");
    
    file.remove(file1);
    file.remove(file2);
}

fn test_wc_lines_only(test.T t) -> void {
    string vigil_bin, string main_script = find_vigil_and_main();
    t.assert(vigil_bin != "", "should find vigil binary");
    
    string test_file = get_temp_path("vigil_wc_test3.txt");
    err e = file.write_all(test_file, "a\nb\nc\n");
    t.assert(e == ok, "should write test file");
    
    string stdout, string stderr, i32 exitCode, err e2 = os.exec(vigil_bin, main_script, "-l", test_file);
    t.assert(e2 == ok, "vigil-wc -l should succeed");
    t.assert(stdout.contains("3 "), "should show 3 lines");
    t.assert(!stdout.contains(" 3 "), "should not show words (no double space before 3)");
    t.assert(!stdout.contains(" 6 "), "should not show bytes");
    
    file.remove(test_file);
}

fn test_wc_empty_file(test.T t) -> void {
    string vigil_bin, string main_script = find_vigil_and_main();
    t.assert(vigil_bin != "", "should find vigil binary");
    
    string test_file = get_temp_path("vigil_wc_empty.txt");
    err e = file.write_all(test_file, "");
    t.assert(e == ok, "should write empty file");
    
    string stdout, string stderr, i32 exitCode, err e2 = os.exec(vigil_bin, main_script, test_file);
    t.assert(e2 == ok, "vigil-wc should succeed on empty file");
    t.assert(stdout.contains("0 0 0"), "should show all zeros");
    
    file.remove(test_file);
}

fn test_wc_missing_file(test.T t) -> void {
    string vigil_bin, string main_script = find_vigil_and_main();
    t.assert(vigil_bin != "", "should find vigil binary");
    
    string missing = get_temp_path("vigil_wc_nonexistent.txt");
    
    string stdout, string stderr, i32 exitCode, err e = os.exec(vigil_bin, main_script, missing);
    t.assert(exitCode != 0, "vigil-wc should fail on missing file");
    t.assert(stderr.contains("vigil-wc:"), "should show error on stderr");
}

fn test_wc_stdin_dash(test.T t) -> void {
    string platform = os.platform();
    if (platform == "windows") {
        return;
    }
    
    string vigil_bin, string main_script = find_vigil_and_main();
    t.assert(vigil_bin != "", "should find vigil binary");
    
    string test_file = get_temp_path("vigil_wc_stdin_test.txt");
    err e = file.write_all(test_file, "stdin test\n");
    t.assert(e == ok, "should write test file");
    
    string sh_cmd = vigil_bin + " " + main_script + " - < " + test_file;
    string stdout, string stderr, i32 exitCode, err e2 = os.exec("sh", "-c", sh_cmd);
    t.assert(e2 == ok, "vigil-wc with - should succeed");
    t.assert(stdout.contains("1 2 11"), "should count stdin correctly");
    
    file.remove(test_file);
}

fn test_wc_no_args_stdin(test.T t) -> void {
    string platform = os.platform();
    if (platform == "windows") {
        return;
    }
    
    string vigil_bin, string main_script = find_vigil_and_main();
    t.assert(vigil_bin != "", "should find vigil binary");
    
    string test_file = get_temp_path("vigil_wc_noargs_test.txt");
    err e = file.write_all(test_file, "no args\n");
    t.assert(e == ok, "should write test file");
    
    string sh_cmd = vigil_bin + " " + main_script + " < " + test_file;
    string stdout, string stderr, i32 exitCode, err e2 = os.exec("sh", "-c", sh_cmd);
    t.assert(e2 == ok, "vigil-wc with no args should succeed");
    t.assert(stdout.contains("1 2 8"), "should count stdin correctly");
    
    file.remove(test_file);
}
