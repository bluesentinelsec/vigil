import "os";
import "file";
import "fmt";

fn main() -> i32 {
    array<string> args = os.args();
    
    if (args.len() < 2) {
        fmt.eprintln("basl-mv: missing file operand");
        return 1;
    }
    
    string src = args[0];
    string dst = args[1];
    
    err e = file.rename(src, dst);
    if (e != ok) {
        fmt.eprintln(f"basl-mv: {e.message()}");
        return 1;
    }
    
    return 0;
}
