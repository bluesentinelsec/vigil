import "file";
import "fmt";
import "json";
import "math";
import "os";
import "path";
import "strings" as strutil;
import "unsafe";

enum Stage {
    Pending,
    Running = 5,
    Done
}

interface Named {
    fn name() -> string;
}

interface Executable {
    fn run() -> i32;
}

class Task implements Named, Executable {
    pub string label;
    pub i32 steps;

    fn init(string label, i32 steps) -> void {
        self.label = label;
        self.steps = steps;
    }

    fn name() -> string {
        return self.label;
    }

    fn run() -> i32 {
        return self.steps;
    }
}

class CheckedNumber {
    pub i32 value;

    fn init(string raw) -> err {
        i32 parsed, err e = i32(raw);
        if (e != ok) {
            return e;
        }
        self.value = parsed;
        return ok;
    }
}

fn ensure(bool condition, string message) -> err {
    if (!condition) {
        return err(message);
    }
    return ok;
}

fn wrap_error(string context, err e) -> err {
    if (e != ok) {
        return err(context + ": " + string(e));
    }
    return ok;
}

fn add(i32 a, i32 b) -> i32 {
    return a + b;
}

fn multiply(i32 a, i32 b) -> i32 {
    return a * b;
}

fn apply_binary(fn(i32, i32) -> i32 op, i32 a, i32 b) -> i32 {
    return op(a, b);
}

fn divide(i32 a, i32 b) -> (i32, err) {
    if (b == 0) {
        return (0, err("division by zero"));
    }
    return (a / b, ok);
}

fn render_name(Named item) -> string {
    return item.name();
}

fn count_steps(Executable item) -> i32 {
    return item.run();
}

fn report_section(string label, err e) -> i32 {
    if (e == ok) {
        fmt.println(f"[PASS] {label}");
        return 0;
    }
    fmt.println(f"[FAIL] {label}: {e}");
    return 1;
}

pub fn test_core_language() -> err {
    const string suite_name = "test_programs";
    const i32 section_count = 6;
    i32 dec = 255;
    i32 hex = 255;
    i32 bin = 255;
    i32 oct = 255;
    err e = ensure(dec == hex && hex == bin && bin == oct, "integer literals should match");
    if (e != ok) {
        return e;
    }
    i32 signed = -7;
    i64 wide = i64(100000);
    f64 ratio = 3.14159;
    u8 byte = u8(255);
    u32 flags = u32(12);
    u64 huge = u64(42);
    bool ready = true;
    string escaped = "line1\nline2";
    string raw = "line1\\nline2";
    string who = "BASL";
    string greeting = f"hello {who.to_lower()}";
    string formatted = f"pi={ratio:.2f}";
    string braces = f"{who}";
    string concatenated = "hello" + " " + "world";
    concatenated += "!";
    e = ensure(signed < 0 && wide > i64(0) && byte == u8(255) && flags == u32(12) && huge == u64(42), "primitive values should initialize");
    if (e != ok) {
        return e;
    }
    e = ensure(ready && escaped.contains("\n") && raw.contains("\\n"), "string literals should behave");
    if (e != ok) {
        return e;
    }
    e = ensure(greeting == "hello basl" && formatted.starts_with("pi=") && braces.contains("BASL"), "f-strings should format");
    if (e != ok) {
        return e;
    }
    e = ensure(concatenated == "hello world!", "string concatenation should work");
    if (e != ok) {
        return e;
    }
    i32 counter = 10;
    counter += 5;
    counter -= 3;
    counter *= 2;
    counter /= 4;
    counter %= 5;
    counter++;
    counter--;
    e = ensure(counter == 1, "compound assignment should be applied in order");
    if (e != ok) {
        return e;
    }
    i32 bitwise = 15 & 255 | 16;
    bitwise = bitwise ^ 3;
    bitwise = bitwise << 1;
    bitwise = bitwise >> 1;
    i32 inverted = ~0;
    e = ensure(bitwise == 28 && inverted == -1, "bitwise operators should work");
    if (e != ok) {
        return e;
    }
    array<i32> nums = [1, 2, 3];
    nums[0] = 9;
    map<string, i32> scores = {"alice": 2};
    scores["alice"] = 3;
    scores["bob"] = 4;
    array<array<string>> nested = [["a"], ["b", "c"]];
    e = ensure(nums[0] == 9 && scores["alice"] == 3 && nested[1][1] == "c", "composite literals should work");
    if (e != ok) {
        return e;
    }
    fn any_callable = add;
    fn(i32, i32) -> i32 typed = multiply;
    i32 via_any = any_callable(2, 3);
    i32 via_typed = apply_binary(typed, 3, 4);
    e = ensure(via_any == 5 && via_typed == 12, "function values should be callable");
    if (e != ok) {
        return e;
    }
    i32 quotient, err div_e = divide(9, 3);
    if (div_e != ok) {
        return div_e;
    }
    i32 exact, err _ = divide(8, 2);
    i32 zero_value, err div_zero = divide(5, 0);
    e = ensure(quotient == 3 && exact == 4 && zero_value == 0 && div_zero != ok, "multi-return should work");
    if (e != ok) {
        return e;
    }
    string as_text = string(wide);
    i32 parsed, err parse_e = i32("42");
    i32 parsed_bad, err parse_bad = i32("not-a-number");
    e = ensure(as_text == "100000" && parsed == 42 && parse_e == ok && parse_bad != ok && parsed_bad == 0, "type conversions should work");
    if (e != ok) {
        return e;
    }
    f64 root = math.sqrt(4.0);
    f64 low = math.min(2.0, 3.0);
    f64 high = math.max(2.0, 3.0);
    e = ensure(root == 2.0 && low == 2.0 && high == 3.0 && math.pi > 3.0, "math helpers should work");
    if (e != ok) {
        return e;
    }
    string dollars = fmt.dollar(12);
    string rendered = fmt.sprintf("%s:%d", suite_name, section_count);
    e = ensure(dollars == "$12.00" && rendered == "test_programs:6", "fmt helpers should work");
    if (e != ok) {
        return e;
    }
    return ok;
}

pub fn test_control_flow() -> err {
    i32 bucket = 0;
    if (2 > 3) {
        bucket = 1;
    } else if (3 > 2) {
        bucket = 2;
    } else {
        bucket = 3;
    }
    err e = ensure(bucket == 2, "if/else if/else should select the right branch");
    if (e != ok) {
        return e;
    }
    i32 while_count = 0;
    while (while_count < 3) {
        while_count++;
    }
    e = ensure(while_count == 3, "while should loop");
    if (e != ok) {
        return e;
    }
    i32 odd_sum = 0;
    for (i32 i = 0; i < 10; i++) {
        if (i == 8) {
            break;
        }
        if (i % 2 == 0) {
            continue;
        }
        odd_sum += i;
    }
    e = ensure(odd_sum == 16, "for loop should honor break and continue");
    if (e != ok) {
        return e;
    }
    array<i32> items = [2, 4, 6];
    i32 total = 0;
    for value in items {
        total += value;
    }
    e = ensure(total == 12, "for-in over arrays should work");
    if (e != ok) {
        return e;
    }
    map<string, i32> counts = {"a": 1, "b": 2};
    i32 pair_sum = 0;
    i32 pair_count = 0;
    for key, value in counts {
        pair_sum += value;
        if (key.len() == 1) {
            pair_count++;
        }
    }
    i32 value_only_sum = 0;
    for value in counts {
        value_only_sum += value;
    }
    e = ensure(pair_sum == 3 && value_only_sum == 3 && pair_count == 2, "for-in over maps should work");
    if (e != ok) {
        return e;
    }
    string int_switch = "unknown";
    switch (odd_sum) {
        case 12:
            int_switch = "wrong";
        case 15, 16:
            int_switch = "matched";
        default:
            int_switch = "default";
    }
    string string_switch = "none";
    switch ("alice") {
        case "bob", "alice":
            string_switch = "known";
        default:
            string_switch = "unknown";
    }
    string computed_switch = "no";
    switch (5 + 7) {
        case items.len() * 4:
            computed_switch = "yes";
        default:
            computed_switch = "no";
    }
    e = ensure(int_switch == "matched" && string_switch == "known" && computed_switch == "yes", "switch should match documented cases");
    if (e != ok) {
        return e;
    }
    return ok;
}

pub fn test_collections_and_methods() -> err {
    string sample = "  Basl Example  ";
    i32 sample_len = sample.len();
    bool has_basl = sample.contains("Basl");
    bool starts = sample.trim().starts_with("Basl");
    bool ends = sample.trim().ends_with("Example");
    string upper = sample.to_upper();
    string lower = sample.to_lower();
    string replaced = sample.replace("Example", "Suite");
    array<string> pieces = "a,b,c".split(",");
    i32 index, bool found_index = "abc".index_of("b");
    string sub, err sub_e = "hello".substr(1, 3);
    array<u8> bytes = "AZ".bytes();
    string second_char, err char_e = "AZ".char_at(1);
    err e = ensure(sample_len == 16 && has_basl && starts && ends && upper == "  BASL EXAMPLE  " && lower == "  basl example  " && replaced == "  Basl Suite  " && pieces.len() == 3 && index == 1 && found_index && sub == "ell" && sub_e == ok && bytes.len() == 2 && bytes[0] == u8(65) && second_char == "Z" && char_e == ok, "string methods should work");
    if (e != ok) {
        return e;
    }
    array<i32> nums = [1, 2, 3];
    nums.push(4);
    i32 popped, err pop_e = nums.pop();
    i32 second, err get_e = nums.get(1);
    err set_e = nums.set(1, 20);
    array<i32> sliced = nums.slice(0, 2);
    bool contains_twenty = nums.contains(20);
    e = ensure(popped == 4 && pop_e == ok && second == 2 && get_e == ok && set_e == ok && nums[1] == 20 && sliced.len() == 2 && contains_twenty, "array methods should work");
    if (e != ok) {
        return e;
    }
    map<string, i32> counts = {"one": 1};
    i32 one, bool found_one = counts.get("one");
    err counts_set = counts.set("two", 2);
    bool has_two = counts.has("two");
    array<string> keys = counts.keys();
    array<i32> values = counts.values();
    i32 removed, bool removed_ok = counts.remove("two");
    e = ensure(one == 1 && found_one && counts_set == ok && has_two && keys.len() == 2 && values.len() == 2 && removed == 2 && removed_ok && !counts.has("two"), "map methods should work");
    if (e != ok) {
        return e;
    }
    string joined = strutil.join(["x", "y", "z"], ",");
    string repeated = strutil.repeat("-", 4);
    e = ensure(joined == "x,y,z" && repeated == "----", "strings module should work");
    if (e != ok) {
        return e;
    }
    return ok;
}

pub fn test_oop_and_errors() -> err {
    Task task = Task("build docs", 3);
    task.label = "verify docs";
    task.steps += 1;
    err e = ensure(task.label == "verify docs" && task.steps == 4, "field assignment should work");
    if (e != ok) {
        return e;
    }
    Named named = task;
    Executable executable = task;
    array<Named> named_items = [task, Task("second", 2)];
    e = ensure(render_name(named) == "verify docs" && count_steps(executable) == 4 && named_items.len() == 2 && render_name(named_items[1]) == "second", "interfaces should support variables, parameters, and arrays");
    if (e != ok) {
        return e;
    }
    CheckedNumber parsed_number, err parsed_e = CheckedNumber("42");
    if (parsed_e != ok) {
        return parsed_e;
    }
    CheckedNumber failed_number, err failed_e = CheckedNumber("bad");
    e = ensure(parsed_number.value == 42 && failed_e != ok && failed_number.value == 0, "fallible construction should work");
    if (e != ok) {
        return e;
    }
    i32 _, err div_e = divide(1, 0);
    e = ensure(div_e != ok, "errors should be returned as values");
    if (e != ok) {
        return e;
    }
    return ok;
}

pub fn test_runtime_modules() -> err {
    string temp_dir = path.join(".tmp", "feature_suite");
    err e = file.mkdir(temp_dir);
    if (e != ok) {
        return wrap_error("file.mkdir", e);
    }
    defer file.remove(temp_dir);
    string text_path = path.join(temp_dir, "data.txt");
    e = file.write_all(text_path, "alpha\nbeta");
    if (e != ok) {
        return wrap_error("file.write_all", e);
    }
    e = file.append(text_path, "\ngamma");
    if (e != ok) {
        return wrap_error("file.append", e);
    }
    string contents, err read_e = file.read_all(text_path);
    if (read_e != ok) {
        return wrap_error("file.read_all", read_e);
    }
    array<string> lines, err lines_e = file.read_lines(text_path);
    if (lines_e != ok) {
        return wrap_error("file.read_lines", lines_e);
    }
    FileStat info, err stat_e = file.stat(text_path);
    if (stat_e != ok) {
        return wrap_error("file.stat", stat_e);
    }
    e = ensure(file.exists(text_path) && contents == "alpha\nbeta\ngamma" && lines.len() == 3 && info.name == "data.txt" && !info.is_dir, "basic file helpers should work");
    if (e != ok) {
        return e;
    }
    string renamed_path = path.join(temp_dir, "renamed.txt");
    e = file.rename(text_path, renamed_path);
    if (e != ok) {
        return wrap_error("file.rename", e);
    }
    defer file.remove(renamed_path);
    array<string> entries, err list_e = file.list_dir(temp_dir);
    if (list_e != ok) {
        return wrap_error("file.list_dir", list_e);
    }
    e = ensure(entries.len() == 1 && entries.contains("renamed.txt"), "file.list_dir should include renamed file");
    if (e != ok) {
        return e;
    }
    string stream_path = path.join(temp_dir, "stream.txt");
    File writer, err writer_e = file.open(stream_path, "w");
    if (writer_e != ok) {
        return wrap_error("file.open(w)", writer_e);
    }
    defer writer.close();
    defer file.remove(stream_path);
    e = writer.write("delta\nomega");
    if (e != ok) {
        return wrap_error("File.write", e);
    }
    File reader, err reader_e = file.open(stream_path, "r");
    if (reader_e != ok) {
        return wrap_error("file.open(r)", reader_e);
    }
    defer reader.close();
    string first_line, err line_e = reader.read_line();
    if (line_e != ok) {
        return wrap_error("File.read_line", line_e);
    }
    string rest, err rest_e = reader.read(64);
    if (rest_e != ok) {
        return wrap_error("File.read", rest_e);
    }
    e = ensure(first_line == "delta" && rest == "omega", "file handles should read and write");
    if (e != ok) {
        return e;
    }
    string absolute_path, err abs_e = path.abs(renamed_path);
    if (abs_e != ok) {
        return wrap_error("path.abs", abs_e);
    }
    e = ensure(path.base(renamed_path) == "renamed.txt" && path.dir(renamed_path) == temp_dir && path.ext(renamed_path) == ".txt" && absolute_path.ends_with("renamed.txt"), "path helpers should work");
    if (e != ok) {
        return e;
    }
    array<string> args = os.args();
    string cwd, err cwd_e = os.cwd();
    if (cwd_e != ok) {
        return wrap_error("os.cwd", cwd_e);
    }
    e = os.set_env("BASL_DOC_CHECK", "1");
    if (e != ok) {
        return wrap_error("os.set_env", e);
    }
    string env_value, bool env_found = os.env("BASL_DOC_CHECK");
    e = ensure(args.len() >= 0 && cwd.len() > 0 && env_found && env_value == "1" && os.platform().len() > 0, "os helpers should work");
    if (e != ok) {
        return e;
    }
    json.Value root, err json_e = json.parse("{\"name\":\"suite\",\"active\":true,\"items\":[1,2,3],\"nested\":{\"label\":\"inner\"}}");
    if (json_e != ok) {
        return wrap_error("json.parse", json_e);
    }
    json.Value nested, err nested_e = root.get("nested");
    if (nested_e != ok) {
        return wrap_error("json.get(nested)", nested_e);
    }
    json.Value items, err items_e = root.get("items");
    if (items_e != ok) {
        return wrap_error("json.get(items)", items_e);
    }
    json.Value second_item, err second_item_e = items.at(1);
    if (second_item_e != ok) {
        return wrap_error("json.at", second_item_e);
    }
    string serialized = json.stringify(root);
    string second_serialized = json.stringify(second_item);
    e = ensure(root.get_string("name") == "suite" && root.get_bool("active") && root.get_i32("missing") == 0 && nested.get_string("label") == "inner" && items.len() == 3 && items.at_i32(0) == 1 && second_serialized == "2" && root.keys().len() == 4 && serialized.contains("\"name\":\"suite\""), "json helpers should work");
    if (e != ok) {
        return e;
    }
    return ok;
}

pub fn test_unsafe_features() -> err {
    string null_text = string(unsafe.null);
    unsafe.Buffer buf = unsafe.alloc(4);
    buf.set(0, 65);
    buf.set(1, 66);
    buf.set(2, 67);
    buf.set(3, u8(0));
    u8 first = buf.get(0);
    u32 packed = buf.get_u32(0);
    err e = ensure(null_text == "null" && buf.len() == 4 && first == u8(65) && packed > u32(0), "unsafe.Buffer should work");
    if (e != ok) {
        return e;
    }
    unsafe.Layout layout = unsafe.layout("i32", "u8");
    unsafe.Struct record = layout.new();
    record.set(0, 42);
    record.set(1, u8(7));
    i32 left = record.get(0);
    u8 right = record.get(1);
    e = ensure(left == 42 && right == u8(7), "unsafe.Layout and unsafe.Struct should work");
    if (e != ok) {
        return e;
    }
    return ok;
}

pub fn run_demo() -> i32 {
    const string suite_name = "test_programs";
    const i32 section_count = 6;
    i32 failures = 0;
    fmt.print(strutil.repeat("=", 8));
    fmt.println(f" {suite_name} feature coverage ");
    failures += report_section("core language", test_core_language());
    failures += report_section("control flow", test_control_flow());
    failures += report_section("collections and methods", test_collections_and_methods());
    failures += report_section("oop and errors", test_oop_and_errors());
    failures += report_section("runtime modules", test_runtime_modules());
    failures += report_section("unsafe features", test_unsafe_features());
    fmt.println(f"Summary: {section_count - failures}/{section_count} sections passed");
    return failures;
}
