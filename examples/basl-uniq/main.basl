import "io";
import "fmt";

fn main() -> i32 {
    string prev = "";
    bool first = true;
    
    while (true) {
        string line, err e = io.read_line();
        if (e != ok) {
            break;
        }
        
        if (first || line != prev) {
            fmt.println(line);
            prev = line;
            first = false;
        }
    }
    
    return 0;
}
