import "t";
import "os";

fn test_uniq_basic() -> void {
    os.exec("sh", "-c", "printf 'a\\na\\nb\\nb\\nb\\nc\\n' > /tmp/basl_uniq_in.txt");
    
    string out, string errs, err e = os.exec("sh", "-c", "./basl examples/basl-uniq/main.basl < /tmp/basl_uniq_in.txt");
    t.assert(string(e) == "ok", "uniq should exit 0");
    t.assert(out == "a\nb\nc\n", "should remove consecutive duplicates");
}

fn main() -> i32 {
    return 0;
}
