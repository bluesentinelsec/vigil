import "t";
import "os";
import "file";

// Note: Tests use sh for stdin redirection, which requires Unix-like shell.
// Windows users should run tests in WSL, Git Bash, or similar environment.

fn test_uniq_basic() -> void {
    file.write_all("test_uniq_in.txt", "a\na\nb\nb\nb\nc\n");
    
    string out, string errs, err e = os.exec("sh", "-c", "./basl examples/basl-uniq/main.basl < test_uniq_in.txt");
    t.assert(string(e) == "ok", "uniq should exit 0");
    t.assert(out == "a\nb\nc\n", "should remove consecutive duplicates");
    
    file.remove("test_uniq_in.txt");
}

fn main() -> i32 {
    return 0;
}
